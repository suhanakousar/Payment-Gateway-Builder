# PayLite environment template.
# Copy to .env (gitignored) and fill in real values. Never commit .env.

# ── Core ──────────────────────────────────────────────────────────────
# Postgres connection string. Neon/Supabase/local — anything Postgres 14+.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Used for cookie signing AND AES-256-GCM encryption of stored PAN /
# bank account / vendor IDs. Must be ≥24 chars in production. Rotating
# this loses access to previously-encrypted columns.
SESSION_SECRET=change-me-to-at-least-24-random-chars

# Default provider when a merchant doesn't have a preferred one. Currently
# only "cashfree" is wired for live multi-merchant flow.
DEFAULT_PROVIDER=cashfree

# Optional: comma-separated routing weights. Keep cashfree-only in prod.
PROVIDER_WEIGHTS=cashfree:100

# ── Cashfree (required for real money flow) ──────────────────────────
# Get these from cashfree.com → Developers → API Keys.
# IMPORTANT: test with SANDBOX keys (cfsk_test_…) first. Only switch to
# production keys (cfsk_ma_prod_…) after end-to-end verification.
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# Webhook signing secret. Get from Cashfree Dashboard → Developers →
# Webhooks → (your webhook) → "Webhook Secret".
CASHFREE_WEBHOOK_SECRET=

# Auto-selects from the keys' prefix if unset:
#   sandbox keys → https://sandbox.cashfree.com/pg
#   production   → https://api.cashfree.com/pg
# Set explicitly to force a base.
# CASHFREE_BASE=https://sandbox.cashfree.com/pg
# CASHFREE_API_VERSION=2023-08-01

# ── Optional ─────────────────────────────────────────────────────────
# LOG_LEVEL=debug
# CORS_ORIGIN=http://localhost:19926
# WEBHOOK_SECRET=fallback-for-outbound-merchant-webhooks
